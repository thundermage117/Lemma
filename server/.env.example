# Runtime DB URL (can be pooled)
DATABASE_URL="postgresql://postgres:postgres@localhost:5432/lemma?schema=public"

# Direct DB URL used by Prisma Migrate
DIRECT_URL="postgresql://postgres:postgres@localhost:5432/lemma?schema=public"

PORT=3001

# Comma-separated browser origins allowed to call the API.
# Same-origin requests are always allowed automatically.
ALLOWED_ORIGINS="http://localhost:5173,http://127.0.0.1:5173"

# Supabase project URL used for JWT verification and auth issuer defaults.
SUPABASE_URL="https://YOUR_PROJECT_REF.supabase.co"

# Optional JWT verification overrides (defaults shown).
SUPABASE_JWT_ISSUER="https://YOUR_PROJECT_REF.supabase.co/auth/v1"
SUPABASE_JWT_AUDIENCE="authenticated"

# JSON and form body size limit.
REQUEST_BODY_LIMIT="64kb"

# Rate limiter settings for /api/*.
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX_REQUESTS=300

# Optional CSP rollout toggle. Set to true to emit Content-Security-Policy-Report-Only first.
CSP_REPORT_ONLY="false"

# Optional comma-separated extra connect-src entries for CSP
# (for third-party APIs beyond Supabase and same-origin requests).
# Include external storage/CDN origins when needed (for non-Supabase hosts), e.g.
# CSP_EXTRA_CONNECT_SRC="https://pub-<id>.r2.dev,https://cdn.example.com"
CSP_EXTRA_CONNECT_SRC=""

# Optional comma-separated list of user UUIDs to seed in one run.
# When set, data is refreshed only for these users (other users are untouched).
# Example:
# SEED_USER_IDS="demo-user-uuid,your-user-uuid"
SEED_USER_IDS=""

# Backward-compatible single seed owner for demo/sample data.
# Used only when SEED_USER_IDS is empty.
SEED_USER_ID="00000000-0000-0000-0000-000000000000"

# Optional comma-separated list of user UUIDs that should be read-only via API.
# Use this to prevent demo users from creating/updating/deleting records.
READ_ONLY_USER_IDS=""

# Optional Gemini API key for AI features (set to empty string to disable).
GEMINI_API_KEY=your_key_here
