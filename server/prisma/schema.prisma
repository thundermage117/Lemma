generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

enum BookStatus {
  not_started
  reading
  paused
  finished
}

enum TopicStatus {
  learning
  revised
  strong
}

enum SourceType {
  textbook
  self
  other
}

enum Difficulty {
  easy
  medium
  hard
}

enum ProblemStatus {
  not_started
  attempted
  solved
  solved_with_help
  revisit
}

enum QuestionStatus {
  open
  understood
  revisit
}

model Book {
  id             Int        @id @default(autoincrement())
  title          String
  author         String
  subject        String
  description    String?
  pdfFilename    String?
  totalPages     Int?
  currentPage    Int        @default(0)
  currentChapter String?
  status         BookStatus @default(not_started)
  isActive       Boolean    @default(false)
  createdAt      DateTime   @default(now())
  updatedAt      DateTime   @updatedAt

  topics         Topic[]
  problems       Problem[]
  journalEntries JournalEntry[]
  questions      Question[]
}

model Topic {
  id              Int         @id @default(autoincrement())
  title           String
  subject         String
  summary         String?
  notes           String?
  examples        String?
  confidenceLevel Int         @default(5)
  linkedBookId    Int?
  pageStart       Int?
  pageEnd         Int?
  status          TopicStatus @default(learning)
  createdAt       DateTime    @default(now())
  updatedAt       DateTime    @updatedAt

  book           Book?          @relation(fields: [linkedBookId], references: [id])
  problems       Problem[]
  journalEntries JournalEntry[]
  questions      Question[]
}

model Problem {
  id               Int           @id @default(autoincrement())
  title            String
  sourceType       SourceType    @default(textbook)
  linkedBookId     Int?
  topicId          Int?
  chapterOrSection String?
  pageNumber       Int?
  problemStatement String
  difficulty       Difficulty    @default(medium)
  tags             String?
  status           ProblemStatus @default(not_started)
  attemptNotes     String?
  finalSolution    String?
  mistakesMade     String?
  revisitDate      DateTime?
  createdAt        DateTime      @default(now())
  updatedAt        DateTime      @updatedAt

  book  Book?  @relation(fields: [linkedBookId], references: [id])
  topic Topic? @relation(fields: [topicId], references: [id])
}

model JournalEntry {
  id                  Int      @id @default(autoincrement())
  date                DateTime @default(now())
  whatIStudied        String
  whatConfusedMe      String?
  oneThingIUnderstood String?
  pagesRead           Int?
  linkedBookId        Int?
  linkedTopicId       Int?
  durationMinutes     Int?
  createdAt           DateTime @default(now())
  updatedAt           DateTime @updatedAt

  book  Book?  @relation(fields: [linkedBookId], references: [id])
  topic Topic? @relation(fields: [linkedTopicId], references: [id])
}

model Question {
  id            Int            @id @default(autoincrement())
  text          String
  linkedBookId  Int?
  linkedTopicId Int?
  pageNumber    Int?
  status        QuestionStatus @default(open)
  createdAt     DateTime       @default(now())
  updatedAt     DateTime       @updatedAt

  book  Book?  @relation(fields: [linkedBookId], references: [id])
  topic Topic? @relation(fields: [linkedTopicId], references: [id])
}
