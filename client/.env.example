VITE_SUPABASE_URL="https://YOUR_PROJECT_REF.supabase.co"
VITE_SUPABASE_ANON_KEY="YOUR_SUPABASE_ANON_KEY"

# Optional: hosted PDF base URL (Supabase Storage, R2, S3, etc).
# If set, a book PDF value like "Abbott.pdf" resolves to
# "<VITE_PDF_BASE_URL>/Abbott.pdf" in the reader.
# Example (Supabase public bucket):
# https://<project-ref>.supabase.co/storage/v1/object/public/books
VITE_PDF_BASE_URL=""

# Optional: one-click shared demo login (must be a real Supabase Auth user)
VITE_DEMO_EMAIL="demo@lemma.local"
VITE_DEMO_PASSWORD="CHANGE_ME_DEMO_PASSWORD"
